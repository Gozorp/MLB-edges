# =============================================================================
# Secrets and credentials — never commit
# =============================================================================
.env
.env.*
*.key
*.pem
secrets/

# =============================================================================
# Python build/cache artifacts
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# =============================================================================
# Vendored / locally-installed Python libraries — these are huge and
# should be re-installed via `pip install -r requirements.txt`
# =============================================================================
.pip_extra/
.pip-target/
.pip-target2/
.pylib/
.python_libs/
venv/
.venv/
env/

# =============================================================================
# Cached external data — re-downloaded on each scrape run, no value in git
# =============================================================================
data/savant/
data/savant_extra/
data/savant_2025/
data/savant_bat_tracking/
data/statcast_cache/
data/pybaseball_cache/
data/feature_cache/
data/news_cache/
data/odds_cache/
data/weather_cache/
data/pitch_logs/
data/bref/
data/fangraphs/
data/state/auto_weight_update.lock

# Large derived artifacts (regenerable)
*.parquet
# Whitelist umpire effects DB (built weekly by .github/workflows/umpire-refresh.yml).
# These files are committed back to the repo so build_pipeline.py picks up the
# refreshed deltas without an extra fetch step.
!data/umpire_assignments.parquet
!data/umpire_effects.parquet
*.pkl
*.feather
*.h5
*.npy

# But: model bundles in models/ MUST be tracked so the GitHub Actions
# auto-runner has a model to score with.  These are small (<10MB each)
# and required at scoring time.
!models/
!models/*.pkl
!models/*.json
models/archive/

# =============================================================================
# Run logs (regenerated on every run, no value in versioning)
# =============================================================================
*.log
logs/

# =============================================================================
# Editor / OS noise
# =============================================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# =============================================================================
# Local development scratch
# =============================================================================
tmp/
scratch/
*.tmp
*.bash_view

# =============================================================================
# Sandbox / runtime cache directories that leaked from earlier env setups
# =================